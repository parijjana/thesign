# Local Claude Code settings (per-machine permissions)
.claude/settings.local.json

# Policy: LLM-collaboration files stay local — never on GitHub.
# (Coding standards, design principles, lessons-learnt, UI/UX guidelines
# about how we work — anything not about the game itself.)
# Convention: such files live in meta/ so this rule catches them automatically.
meta/

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store

# Flutter/Dart (takes effect once the project is created in M0)
.dart_tool/
.packages
build/
.flutter-plugins
.flutter-plugins-dependencies
*.iml
.idea/
android/.gradle/
ios/Pods/
windows/flutter/ephemeral/
linux/flutter/ephemeral/
macos/Flutter/ephemeral/

# Claude Code agent workspace + LLM-meta skills (kept local, see memory)
.claude/
